{
  "name": "reactive-state",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/reactive-state/src",
  "prefix": "angular-kit",
  "tags": [],
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/reactive-state/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/reactive-state/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/reactive-state/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/reactive-state/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/reactive-state/**/*.ts",
          "libs/reactive-state/**/*.html",
          "libs/reactive-state/package.json",
          "libs/reactive-state/effects/**/*.ts",
          "libs/reactive-state/effects/**/*.html",
          "libs/reactive-state/actions/**/*.ts",
          "libs/reactive-state/actions/**/*.html",
          "libs/reactive-state/hooks/**/*.ts",
          "libs/reactive-state/hooks/**/*.html"
        ]
      }
    }
  }
}
